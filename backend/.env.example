# Runtime
NODE_ENV=production
PORT=3005
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
JWT_SECRET=GANTI_DENGAN_SECRET_ACAK
DEFAULT_USER_PIN=1234

# Origin dan URL publik
CORS_ORIGINS=https://YOUR_FRONTEND.vercel.app
FRONTEND_BASE_URL=https://YOUR_FRONTEND.vercel.app
BACKEND_PUBLIC_URL=https://api-kasrt.example.com

# Cron reminder jimpitan
CRON_SECRET=GANTI_DENGAN_SECRET_ACAK_MINIMAL_16_KARAKTER

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Redis (opsional)
REDIS_URL=

# Reminder WhatsApp: off, fonnte, atau http
WA_REMINDER_PROVIDER=off
FONNTE_TOKEN=
WA_GATEWAY_URL=
WA_GATEWAY_BASE_URL=
WA_GATEWAY_SECRET=
WA_REMINDER_MIN_DELAY_MS=1000
WA_REMINDER_MAX_DELAY_MS=3000

# Konfigurasi opsional
LINGKUNGAN_TARGET_BULANAN=
DEBUG_JIMPITAN=false
